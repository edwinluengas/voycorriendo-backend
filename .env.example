# ─────────────────────────────────────────────────────────
# MANDADITOS — Variables de entorno
# Copia este archivo como .env y llena los valores
# NUNCA subas .env a GitHub
# ─────────────────────────────────────────────────────────

# SERVIDOR
PORT=3000
NODE_ENV=development

# BASE DE DATOS (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mandaditos_db
DB_USER=mandaditos_user
DB_PASSWORD=tu_password_aqui

# JWT (Genera uno seguro: openssl rand -base64 64)
JWT_SECRET=cambia_esto_por_algo_muy_secreto_y_largo
JWT_EXPIRES_IN=7d

# TWILIO (OTP / SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# FIREBASE (Notificaciones Push)
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# MERCADO PAGO
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=

# GOOGLE MAPS API
GOOGLE_MAPS_API_KEY=

# CORS - Origenes permitidos
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:19006

# TELEGRAM BOT (Rosie - notificaciones internas)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
