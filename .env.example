# ─────────────────────────────────────────────────────────
# VOYCORRIENDO — Variables de entorno
# Copia este archivo como .env y llena los valores
# NUNCA subas .env a GitHub
# ─────────────────────────────────────────────────────────

# SERVIDOR
PORT=3000
NODE_ENV=development

# BASE DE DATOS (PostgreSQL)
# ─── Opción A: local para desarrollo ─────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=voycorriendo_db
DB_USER=voycorriendo_user
DB_PASSWORD=tu_password_aqui
DB_SSL=false

# ─── Opción B: Supabase en Railway/Render/Fly ────────────
# ⚠️ IMPORTANTE: NO uses el host directo db.<ref>.supabase.co en Railway.
#    Solo resuelve por IPv6 y Railway solo tiene IPv4 → CRASH.
#    Usa el TRANSACTION POOLER (IPv4-compatible):
#
# DB_HOST=aws-0-us-east-1.pooler.supabase.com   (ajusta la región)
# DB_PORT=6543
# DB_NAME=postgres
# DB_USER=postgres.<tu-project-ref>             (ej: postgres.uxchuyfwxhkpjykbgahy)
# DB_PASSWORD=tu_password
# DB_SSL=true

# JWT (Genera uno seguro: openssl rand -base64 64)
JWT_SECRET=cambia_esto_por_algo_muy_secreto_y_largo
JWT_EXPIRES_IN=7d

# TWILIO (OTP / SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# FIREBASE (Notificaciones Push)
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# MERCADO PAGO
MERCADOPAGO_ACCESS_TOKEN=
# La public key NO la usa este backend — se pega en voycorriendo-app/app.json
# (extra.MP_PUBLIC_KEY) para que la app tokenice tarjetas directo con MP.
# Debe ser del MISMO par (test o prod) que MERCADOPAGO_ACCESS_TOKEN de arriba.
MERCADOPAGO_PUBLIC_KEY=
# URL pública donde MP enviará webhooks (ngrok en desarrollo)
API_PUBLIC_URL=http://localhost:3000
# Deep link de la app móvil para regresar tras el pago
APP_DEEP_LINK=voycorriendo://
# Límite de pago en efectivo (MXN)
LIMITE_EFECTIVO=1000

# ─────────────────────────────────────────────────────────
# GOOGLE MAPS (cálculo de distancia real por carretera)
# Sin esta key el backend cae a haversine (línea recta).
# Habilita "Distance Matrix API" en Google Cloud Console.
# ─────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=

# ─────────────────────────────────────────────────────────
# MODELO ECONÓMICO (todo en pesos mexicanos / porcentajes)
# Estos valores tienen defaults razonables; solo descoméntalos
# si quieres sobreescribirlos para tu zona.
# ─────────────────────────────────────────────────────────
# Tarifa MÍNIMA / base de envío (MXN). Piso absoluto.
# Ningún pedido se cobra por debajo de este monto, aunque haya promoción.
TARIFA_MINIMA_ENVIO=25

# Tarifas de envío al cliente (MXN)
# ZONA_A_FEE=25         # 0-2 km
# ZONA_B_FEE=40         # 2-5 km
# ZONA_C_FEE=55         # 5-10 km
# RECARGO_HORA_PICO=10
# RECARGO_CLIMA=5

# Pago al repartidor por pedido (MXN)
# COURIER_PAY_SHORT=20  # ≤ 2 km
# COURIER_PAY_MEDIUM=30 # 2-5 km
# COURIER_PAY_LONG=45   # > 5 km

# Comisiones por categoría de negocio (%)
# COMMISSION_RESTAURANTS=12
# COMMISSION_STORES=10
# COMMISSION_PHARMACY=8
# COMMISSION_LIQUOR=12

# Distancia máxima de cobertura (km)
# MAX_DISTANCE_KM=10

# Bonos al repartidor (MXN) - fase 2
# BONUS_RAIN=5
# BONUS_PEAK=5
# BONUS_METAS_10=20